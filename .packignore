# 压缩时排除的文件和目录
# 使用方法：tar --exclude-from=.packignore -czf newapi_export.tar.gz .

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 环境变量（敏感信息）
.env
config.ini
*.key
*.pem

# IDE和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 日志文件（可选，如果想保留则注释掉）
# logs/*.log
# logs/cron.log

# 备份文件（服务器会重新生成）
backups/*.gz
backups/*.db

# Git相关（如果有）
.git/
.gitignore

# 测试文件
test_*.py
*_test.py

# 临时文件
*.tmp
*.bak
*.orig

# Windows相关
desktop.ini
$RECYCLE.BIN/

# 可选：如果数据库很大且服务器有自己的数据源，可以不传
# newapi_warehouse.db
